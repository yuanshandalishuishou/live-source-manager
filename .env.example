# =============================================================
# .env 示例文件 — Live Source Manager Docker 配置
# =============================================================
# 复制此文件为 .env 并修改相应配置

# 端口配置
NGINX_PORT=12345
WEB_PORT=23456

# 测试参数
TEST_TIMEOUT=10
CONCURRENT_THREADS=50
OUTPUT_FILENAME=live.m3u

# 定时任务（Cron 表达式）
UPDATE_CRON=0 6,12,18,22 * * *

# 密码配置（务必修改！）
WEB_ADMIN_PASSWORD=your_strong_password_here

# 配置加密密钥（务必修改！32字节 base64 编码）
# 生成方式: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
CONFIG_ENCRYPT_KEY=

# 目录映射（可选，默认使用当前目录下的子目录）
# CONFIG_DIR=./config
# LOG_DIR=./logs
# OUTPUT_DIR=./output
# DATA_DIR=./data
# SOURCES_DIR=./sources
